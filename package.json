{
  "name": "@letta-ai/letta-acp",
  "version": "0.1.1",
  "packageManager": "bun@1.3.0",
  "description": "ACP (Agent Client Protocol) adapter for Letta agents — exposes Letta over ACP v1 so editors like Zed can drive a stateful Letta agent.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/letta-ai/letta-acp.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "letta-acp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "start": "bun src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "typecheck": "tsc --noEmit",
    "test:client": "bun test-client.ts",
    "check": "bun run typecheck && bun run build"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "typescript": "^5.9.0"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^1.3.0",
    "@letta-ai/letta-agent-sdk": "^0.2.6"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
